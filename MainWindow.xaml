<Window x:Class="DNS_Switcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DNS Switcher"
        Height="780" Width="1080"
        MinHeight="640" MinWidth="860"
        WindowStartupLocation="CenterScreen"
        Background="#0D0D1A"
        FontFamily="Segoe UI"
        Foreground="#E0E0F0">

    <Window.Resources>

        <!-- ═══ Colour Palette ═══════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="BgBrush"          Color="#0D0D1A"/>
        <SolidColorBrush x:Key="SurfaceBrush"     Color="#141426"/>
        <SolidColorBrush x:Key="CardBrush"        Color="#1C1C2E"/>
        <SolidColorBrush x:Key="CardHoverBrush"   Color="#252540"/>
        <SolidColorBrush x:Key="CardBorderBrush"  Color="#2E2E4A"/>
        <SolidColorBrush x:Key="AccentBrush"      Color="#5B6CF5"/>
        <SolidColorBrush x:Key="Accent2Brush"     Color="#7380F7"/>
        <SolidColorBrush x:Key="SuccessBrush"     Color="#3BC97E"/>
        <SolidColorBrush x:Key="WarningBrush"     Color="#F5A623"/>
        <SolidColorBrush x:Key="ErrorBrush"       Color="#E85050"/>
        <SolidColorBrush x:Key="TextBrush"        Color="#EAEAF0"/>
        <SolidColorBrush x:Key="SubTextBrush"     Color="#7A7A9A"/>
        <SolidColorBrush x:Key="DividerBrush"     Color="#252540"/>
        <SolidColorBrush x:Key="GoogleBrush"      Color="#4285F4"/>
        <SolidColorBrush x:Key="CloudflareBrush"  Color="#F38020"/>
        <SolidColorBrush x:Key="Quad9Brush"       Color="#A855F7"/>
        <SolidColorBrush x:Key="LogBgBrush"       Color="#08081A"/>
        <SolidColorBrush x:Key="LogTextBrush"     Color="#9090CC"/>

        <!-- ═══ Section label ════════════════════════════════════════════════ -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource SubTextBrush}"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,0,0,7"/>
        </Style>

        <!-- ═══ Dark TextBox ════════════════════════════════════════════════ -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background"  Value="{StaticResource CardBrush}"/>
            <Setter Property="Foreground"  Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"     Value="8,6"/>
            <Setter Property="FontFamily"  Value="Consolas"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Primary Button ══════════════════════════════════════════════ -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"       Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="18,9"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Accent2Brush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#4A5ADF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#252540"/>
                                <Setter Property="Foreground" Value="#4A4A6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Secondary Button ════════════════════════════════════════════ -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background"       Value="#1C1C2E"/>
            <Setter Property="Foreground"       Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="14,8"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"  Value="#252540"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#12122A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#4A4A6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Danger Button ═══════════════════════════════════════════════ -->
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource SecondaryBtn}">
            <Setter Property="Foreground"  Value="{StaticResource ErrorBrush}"/>
            <Setter Property="BorderBrush" Value="#5A2020"/>
        </Style>

        <!-- ═══ Icon Button (small, square) ═════════════════════════════════ -->
        <Style x:Key="IconBtn" TargetType="Button" BasedOn="{StaticResource SecondaryBtn}">
            <Setter Property="Padding"   Value="6,4"/>
            <Setter Property="FontSize"  Value="15"/>
            <Setter Property="MinWidth"  Value="32"/>
        </Style>

        <!-- ═══ Preset card ══════════════════════════════════════════════════ -->
        <Style x:Key="PresetCard" TargetType="Button">
            <Setter Property="Background"       Value="{StaticResource CardBrush}"/>
            <Setter Property="Foreground"       Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="14,12"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CardBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="Background"  Value="#252540"/>
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="#1A1A35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Adapter ListBox item ═════════════════════════════════════════ -->
        <Style x:Key="AdapterItem" TargetType="ListBoxItem">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="0"/>
            <Setter Property="Margin"           Value="0,2,0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="9"
                                Padding="10,8">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background"   Value="#1A1A2E"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush"  Value="#3B3B5A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background"   Value="#1E1E3C"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush"  Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Dark ListBox ═════════════════════════════════════════════════ -->
        <Style x:Key="DarkListBox" TargetType="ListBox">
            <Setter Property="Background"         Value="Transparent"/>
            <Setter Property="BorderThickness"    Value="0"/>
            <Setter Property="Padding"            Value="0"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource AdapterItem}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <ScrollViewer Focusable="False"
                                      CanContentScroll="True"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Dark CheckBox ════════════════════════════════════════════════ -->
        <Style x:Key="DarkCheck" TargetType="CheckBox">
            <Setter Property="Foreground"  Value="{StaticResource TextBrush}"/>
            <Setter Property="Margin"      Value="0,3,0,3"/>
            <Setter Property="Cursor"      Value="Hand"/>
        </Style>

    </Window.Resources>

    <!-- ════ Root grid: Header / Warning / Main / Log ═══════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 0: Header        -->
            <RowDefinition Height="Auto"/>   <!-- 1: Admin warning -->
            <RowDefinition Height="*"/>      <!-- 2: Main content  -->
            <RowDefinition Height="190"/>    <!-- 3: Log panel     -->
        </Grid.RowDefinitions>

        <!-- ══ Row 0 – Header ══════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="20,13,20,13">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title + status -->
                <StackPanel>
                    <TextBlock Text="DNS Switcher"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock x:Name="StatusLabel"
                               Text="Current DNS: Detecting…"
                               Foreground="{StaticResource SubTextBrush}"
                               FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Badges row -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Discord status badge -->
                    <Border x:Name="DiscordBadge"
                            CornerRadius="20" Padding="10,5"
                            Margin="0,0,8,0"
                            Background="#12122A"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1">
                        <TextBlock x:Name="DiscordBadgeText"
                                   Text="● Discord: checking…"
                                   Foreground="{StaticResource SubTextBrush}"
                                   FontSize="11" FontWeight="SemiBold"/>
                    </Border>

                    <!-- Admin badge -->
                    <Border x:Name="AdminBadge"
                            CornerRadius="20" Padding="12,5"
                            Background="#1A2A1A"
                            BorderBrush="{StaticResource SuccessBrush}"
                            BorderThickness="1">
                        <TextBlock x:Name="AdminBadgeText"
                                   Text="● Administrator"
                                   Foreground="{StaticResource SuccessBrush}"
                                   FontSize="11" FontWeight="SemiBold"/>
                    </Border>

                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Row 1 – Admin Warning ════════════════════════════════════════ -->
        <Border Grid.Row="1" x:Name="AdminWarningPanel"
                Margin="14,8,14,0" Padding="14,10"
                Background="#251A08"
                BorderBrush="#7A5200"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="⚠  Administrator permission required"
                               Foreground="{StaticResource WarningBrush}"
                               FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock Text="This app needs Administrator permission to change DNS settings."
                               Foreground="#B87A20" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" x:Name="RestartAdminBtn"
                        Content="Restart as Administrator"
                        Style="{StaticResource PrimaryBtn}"
                        Background="#7A5200"
                        VerticalAlignment="Center"
                        Click="RestartAdmin_Click"/>
            </Grid>
        </Border>

        <!-- ══ Row 2 – Main content ══════════════════════════════════════════ -->
        <Grid Grid.Row="2" Margin="14,10,14,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270"/>         <!-- Left: adapter list -->
                <ColumnDefinition Width="1"/>           <!-- Divider            -->
                <ColumnDefinition Width="*"/>           <!-- Right: controls    -->
            </Grid.ColumnDefinitions>

            <!-- ── Left panel ──────────────────────────────────────────── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Panel header -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="ACTIVE ADAPTERS"
                               Style="{StaticResource SectionLabel}"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="RefreshBtn"
                            Content="↻" Style="{StaticResource IconBtn}"
                            ToolTip="Refresh adapter list"
                            Click="Refresh_Click"/>
                </Grid>

                <!-- Adapter list -->
                <ListBox Grid.Row="1" x:Name="AdapterListBox"
                         Style="{StaticResource DarkListBox}"
                         SelectionChanged="AdapterListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Colour accent bar -->
                                <Rectangle Grid.Column="0" Width="3" RadiusX="2" RadiusY="2"
                                           Fill="{StaticResource AccentBrush}"
                                           VerticalAlignment="Stretch" Margin="0,2,0,2"/>
                                <!-- Adapter info -->
                                <StackPanel Grid.Column="1" Margin="9,0,0,0">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{StaticResource TextBrush}"
                                               FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{Binding Description}"
                                               Foreground="{StaticResource SubTextBrush}"
                                               FontSize="10" TextTrimming="CharacterEllipsis"
                                               Margin="0,1,0,3"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="IPv4 "
                                                   Foreground="#4A4A6A" FontSize="10"/>
                                        <TextBlock Text="{Binding IPv4DnsDisplay}"
                                                   Foreground="{StaticResource SuccessBrush}"
                                                   FontSize="10" FontFamily="Consolas"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="IPv6 "
                                                   Foreground="#4A4A6A" FontSize="10"/>
                                        <TextBlock Text="{Binding IPv6DnsDisplay}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontSize="10" FontFamily="Consolas"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Empty state -->
                <TextBlock Grid.Row="2" x:Name="NoAdaptersText"
                           Text="No active adapters found"
                           Foreground="{StaticResource SubTextBrush}"
                           FontSize="11" HorizontalAlignment="Center"
                           Margin="0,6,0,0" Visibility="Collapsed"/>
            </Grid>

            <!-- Vertical divider -->
            <Rectangle Grid.Column="1" Fill="{StaticResource DividerBrush}"
                       Width="1" VerticalAlignment="Stretch" Margin="5,0"/>

            <!-- ── Right panel ──────────────────────────────────────────── -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="14,0,4,14">

                    <!-- ── DNS Presets ─────────────────────────────────── -->
                    <TextBlock Text="DNS PRESETS" Style="{StaticResource SectionLabel}"/>

                    <UniformGrid Columns="3" Margin="0,0,0,14">

                        <!-- Google -->
                        <Button x:Name="GoogleBtn"
                                Style="{StaticResource PresetCard}"
                                Margin="0,0,5,0"
                                Click="Google_Click">
                            <StackPanel>
                                <TextBlock Text="Google"
                                           Foreground="{StaticResource GoogleBrush}"
                                           FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="8.8.8.8  /  8.8.4.4"
                                           Foreground="{StaticResource SubTextBrush}"
                                           FontFamily="Consolas" FontSize="10"
                                           Margin="0,3,0,0"/>
                                <TextBlock Text="Fast &amp; reliable"
                                           Foreground="#4A4A6A" FontSize="9"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- Cloudflare -->
                        <Button x:Name="CloudflareBtn"
                                Style="{StaticResource PresetCard}"
                                Margin="3,0,3,0"
                                Click="Cloudflare_Click">
                            <StackPanel>
                                <TextBlock Text="Cloudflare"
                                           Foreground="{StaticResource CloudflareBrush}"
                                           FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="1.1.1.1  /  1.0.0.1"
                                           Foreground="{StaticResource SubTextBrush}"
                                           FontFamily="Consolas" FontSize="10"
                                           Margin="0,3,0,0"/>
                                <TextBlock Text="Privacy-focused, fastest"
                                           Foreground="#4A4A6A" FontSize="9"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- Quad9 -->
                        <Button x:Name="Quad9Btn"
                                Style="{StaticResource PresetCard}"
                                Margin="5,0,0,0"
                                Click="Quad9_Click">
                            <StackPanel>
                                <TextBlock Text="Quad9"
                                           Foreground="{StaticResource Quad9Brush}"
                                           FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="9.9.9.9  /  149.112…"
                                           Foreground="{StaticResource SubTextBrush}"
                                           FontFamily="Consolas" FontSize="10"
                                           Margin="0,3,0,0"/>
                                <TextBlock Text="Security-focused"
                                           Foreground="#4A4A6A" FontSize="9"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>
                    </UniformGrid>

                    <!-- ── Custom DNS ──────────────────────────────────── -->
                    <TextBlock Text="CUSTOM DNS" Style="{StaticResource SectionLabel}"/>

                    <Border Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1" CornerRadius="10"
                            Padding="14,12" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- IPv4 heading -->
                            <StackPanel Grid.Row="0" Grid.ColumnSpan="3"
                                        Orientation="Horizontal" Margin="0,0,0,6">
                                <Rectangle Width="8" Height="8" RadiusX="2" RadiusY="2"
                                           Fill="{StaticResource SuccessBrush}"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="IPv4"
                                           Foreground="{StaticResource SuccessBrush}"
                                           FontSize="10" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="Primary"
                                           Foreground="{StaticResource SubTextBrush}"
                                           FontSize="10" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtIPv4Primary"
                                         Style="{StaticResource DarkTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock Text="Secondary"
                                           Foreground="{StaticResource SubTextBrush}"
                                           FontSize="10" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtIPv4Secondary"
                                         Style="{StaticResource DarkTextBox}"/>
                            </StackPanel>

                            <!-- IPv6 heading -->
                            <StackPanel Grid.Row="4" Grid.ColumnSpan="3"
                                        Orientation="Horizontal" Margin="0,0,0,6">
                                <Rectangle Width="8" Height="8" RadiusX="2" RadiusY="2"
                                           Fill="{StaticResource AccentBrush}"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="IPv6"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="10" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Row="6" Grid.Column="0">
                                <TextBlock Text="Primary"
                                           Foreground="{StaticResource SubTextBrush}"
                                           FontSize="10" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtIPv6Primary"
                                         Style="{StaticResource DarkTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="6" Grid.Column="2">
                                <TextBlock Text="Secondary"
                                           Foreground="{StaticResource SubTextBrush}"
                                           FontSize="10" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtIPv6Secondary"
                                         Style="{StaticResource DarkTextBox}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ── Options ─────────────────────────────────────── -->
                    <TextBlock Text="OPTIONS" Style="{StaticResource SectionLabel}"/>

                    <Border Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1" CornerRadius="10"
                            Padding="14,12" Margin="0,0,0,14">
                        <StackPanel>

                            <!-- Set IPv6 DNS -->
                            <CheckBox x:Name="ChkSetIPv6"
                                      Style="{StaticResource DarkCheck}"
                                      IsChecked="True">
                                <StackPanel>
                                    <TextBlock Text="Set IPv6 DNS too"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="12"/>
                                    <TextBlock Text="Recommended on Windows 11 — IPv6 DNS may override IPv4 DNS."
                                               Foreground="{StaticResource SubTextBrush}"
                                               FontSize="10"/>
                                </StackPanel>
                            </CheckBox>

                            <Rectangle Height="1" Fill="{StaticResource DividerBrush}" Margin="0,8,0,8"/>

                            <!-- Disable IPv6 -->
                            <CheckBox x:Name="ChkDisableIPv6"
                                      Style="{StaticResource DarkCheck}"
                                      IsChecked="False"
                                      Checked="ChkDisableIPv6_Checked"
                                      Unchecked="ChkDisableIPv6_Unchecked">
                                <StackPanel>
                                    <TextBlock Text="Disable IPv6 on selected adapter"
                                               Foreground="{StaticResource ErrorBrush}"
                                               FontSize="12"/>
                                    <TextBlock Text="Only use this if changing IPv6 DNS does not solve the problem."
                                               Foreground="{StaticResource SubTextBrush}"
                                               FontSize="10"/>
                                </StackPanel>
                            </CheckBox>

                            <Rectangle Height="1" Fill="{StaticResource DividerBrush}" Margin="0,8,0,8"/>

                            <!-- Apply to all -->
                            <CheckBox x:Name="ChkApplyAll"
                                      Style="{StaticResource DarkCheck}"
                                      IsChecked="False">
                                <TextBlock Text="Apply to all active adapters"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="12"/>
                            </CheckBox>
                        </StackPanel>
                    </Border>

                    <!-- ── Discord Connectivity ───────────────────────── -->
                    <TextBlock Text="DISCORD CONNECTIVITY" Style="{StaticResource SectionLabel}"/>

                    <Border Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1" CornerRadius="10"
                            Padding="14,12" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource SubTextBrush}" FontSize="11"
                                       TextWrapping="Wrap"
                                       Text="After applying a new DNS, use this to confirm Discord is actually reachable. Tests DNS resolution, ping, and TCP connection to discord.com."/>
                            <Button x:Name="TestDiscordBtn"
                                    Content="⚡  Test Discord Connection"
                                    Style="{StaticResource PrimaryBtn}"
                                    Background="#5865F2"
                                    HorizontalAlignment="Left"
                                    Margin="0,10,0,0"
                                    Click="TestDiscord_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Actions ─────────────────────────────────────── -->
                    <TextBlock Text="ACTIONS" Style="{StaticResource SectionLabel}"/>

                    <WrapPanel>
                        <Button x:Name="ApplyBtn"
                                Content="▶  Apply DNS"
                                Style="{StaticResource PrimaryBtn}"
                                Margin="0,0,8,8"
                                Click="Apply_Click"/>

                        <Button x:Name="RestoreBtn"
                                Content="↺  Restore Automatic DNS"
                                Style="{StaticResource SecondaryBtn}"
                                Margin="0,0,8,8"
                                Click="Restore_Click"/>

                        <Button x:Name="TestBtn"
                                Content="⚡  Test DNS"
                                Style="{StaticResource SecondaryBtn}"
                                Margin="0,0,8,8"
                                Click="Test_Click"/>
                    </WrapPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ══ Row 3 – Log panel ═════════════════════════════════════════════ -->
        <Grid Grid.Row="3" Margin="14,6,14,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Log header -->
            <Grid Grid.Row="0" Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="OUTPUT LOG"
                           Style="{StaticResource SectionLabel}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Clear"
                        Style="{StaticResource IconBtn}"
                        Padding="10,3" FontSize="11"
                        Click="ClearLog_Click"/>
            </Grid>

            <!-- Log TextBox -->
            <TextBox Grid.Row="1" x:Name="LogBox"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     Background="{StaticResource LogBgBrush}"
                     Foreground="{StaticResource LogTextBrush}"
                     BorderBrush="#1A1A30"
                     BorderThickness="1"
                     FontFamily="Consolas"
                     FontSize="11"
                     Padding="10,8"
                     VerticalContentAlignment="Top"/>
        </Grid>

    </Grid>
</Window>
