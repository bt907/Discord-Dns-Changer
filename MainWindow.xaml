<Window x:Class="DNS_Switcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Discord DNS Switcher"
        Height="820" Width="1080"
        MinHeight="680" MinWidth="880"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/icon.png"
        Background="#0B0B18"
        FontFamily="Segoe UI"
        Foreground="#E4E4F0"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.Resources>

        <!-- ═══ Palette ═══════════════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="BgBrush"           Color="#0B0B18"/>
        <SolidColorBrush x:Key="SurfaceBrush"      Color="#111120"/>
        <SolidColorBrush x:Key="Surface2Brush"     Color="#16162A"/>
        <SolidColorBrush x:Key="CardBrush"         Color="#1A1A2E"/>
        <SolidColorBrush x:Key="CardBorderBrush"   Color="#28284A"/>
        <SolidColorBrush x:Key="AccentBrush"       Color="#5865F2"/>
        <SolidColorBrush x:Key="AccentHoverBrush"  Color="#6C7BFF"/>
        <SolidColorBrush x:Key="AccentMutedBrush"  Color="#2A2D5E"/>
        <SolidColorBrush x:Key="SuccessBrush"      Color="#3EC97E"/>
        <SolidColorBrush x:Key="SuccessMuted"      Color="#1A3A2A"/>
        <SolidColorBrush x:Key="WarningBrush"      Color="#F5A623"/>
        <SolidColorBrush x:Key="WarningMuted"      Color="#3A2A08"/>
        <SolidColorBrush x:Key="ErrorBrush"        Color="#E85454"/>
        <SolidColorBrush x:Key="ErrorMuted"        Color="#3A1212"/>
        <SolidColorBrush x:Key="TextBrush"         Color="#EAEAF2"/>
        <SolidColorBrush x:Key="SubTextBrush"      Color="#6A6A90"/>
        <SolidColorBrush x:Key="DimTextBrush"      Color="#3E3E5A"/>
        <SolidColorBrush x:Key="DividerBrush"      Color="#1E1E38"/>
        <SolidColorBrush x:Key="GoogleBrush"       Color="#4285F4"/>
        <SolidColorBrush x:Key="CloudflareBrush"   Color="#F6821F"/>
        <SolidColorBrush x:Key="Quad9Brush"        Color="#A855F7"/>
        <SolidColorBrush x:Key="LogBgBrush"        Color="#070712"/>
        <SolidColorBrush x:Key="LogTextBrush"      Color="#7878A8"/>

        <!-- ═══ Typography helpers ════════════════════════════════════════════ -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource SubTextBrush}"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,0,0,8"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
        </Style>

        <Style x:Key="CardSub" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource SubTextBrush}"/>
            <Setter Property="FontSize"    Value="10.5"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- ═══ TextBox ═══════════════════════════════════════════════════════ -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource Surface2Brush}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="9,7"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="CaretBrush"      Value="{StaticResource AccentBrush}"/>
            <Setter Property="SelectionBrush"  Value="{StaticResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Primary Button ════════════════════════════════════════════════ -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,10"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#4A58D8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#1E1E3A"/>
                                <Setter Property="Foreground" Value="#3A3A5A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Secondary Button ══════════════════════════════════════════════ -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource CardBrush}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="16,9"/>
            <Setter Property="FontSize"        Value="12.5"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background"  Value="#20203C"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0E0E22"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground"                  Value="#3A3A5A"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#1E1E38"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Danger Button ═════════════════════════════════════════════════ -->
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource SecondaryBtn}">
            <Setter Property="Foreground"  Value="{StaticResource ErrorBrush}"/>
            <Setter Property="BorderBrush" Value="#5A1818"/>
        </Style>

        <!-- ═══ Ghost / Icon Button ═══════════════════════════════════════════ -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource SubTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1A1A30"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0E0E24"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Preset Card Button ════════════════════════════════════════════ -->
        <Style x:Key="PresetCard" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource CardBrush}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Outer"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Outer" Property="Background"  Value="#1E1E38"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Outer" Property="Background" Value="#141428"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Adapter ListBoxItem ═══════════════════════════════════════════ -->
        <Style x:Key="AdapterItem" TargetType="ListBoxItem">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Margin"          Value="0,3,0,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="10,10">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background"  Value="#14142A"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#2E2E52"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background"  Value="#18183A"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ ListBox ═══════════════════════════════════════════════════════ -->
        <Style x:Key="DarkListBox" TargetType="ListBox">
            <Setter Property="Background"         Value="Transparent"/>
            <Setter Property="BorderThickness"    Value="0"/>
            <Setter Property="Padding"            Value="0"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource AdapterItem}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <ScrollViewer Focusable="False" CanContentScroll="True"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ CheckBox ══════════════════════════════════════════════════════ -->
        <Style x:Key="DarkCheck" TargetType="CheckBox">
            <Setter Property="Foreground"  Value="{StaticResource TextBrush}"/>
            <Setter Property="Margin"      Value="0,2,0,2"/>
            <Setter Property="Cursor"      Value="Hand"/>
        </Style>

        <!-- ═══ Info Card (static panel) ══════════════════════════════════════ -->
        <Style x:Key="InfoCard" TargetType="Border">
            <Setter Property="Background"        Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush"       Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="CornerRadius"      Value="10"/>
            <Setter Property="Padding"           Value="16,13"/>
            <Setter Property="Margin"            Value="0,0,0,14"/>
        </Style>

        <!-- ═══ Badge ═════════════════════════════════════════════════════════ -->
        <Style x:Key="Badge" TargetType="Border">
            <Setter Property="CornerRadius"    Value="20"/>
            <Setter Property="Padding"         Value="11,5"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

    </Window.Resources>

    <!-- ════ Root grid ═══════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: Header       -->
            <RowDefinition Height="Auto"/>  <!-- 1: Warning bar  -->
            <RowDefinition Height="*"/>     <!-- 2: Main         -->
            <RowDefinition Height="210"/>   <!-- 3: Log          -->
        </Grid.RowDefinitions>

        <!-- ══ Row 0 – Header ════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
            </Border.Effect>
            <Grid Margin="18,12,18,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="Assets/icon.png" Width="40" Height="40" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Discord DNS Switcher"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock x:Name="StatusLabel"
                                   Text="Detecting adapters…"
                                   Foreground="{StaticResource SubTextBrush}"
                                   FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Spacer -->
                <Grid Grid.Column="1"/>

                <!-- Badges -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,2,0">

                    <Border x:Name="DiscordBadge" Style="{StaticResource Badge}"
                            Background="#10103A" BorderBrush="{StaticResource CardBorderBrush}"
                            Margin="0,0,8,0">
                        <TextBlock x:Name="DiscordBadgeText"
                                   Text="● Discord: checking…"
                                   Foreground="{StaticResource SubTextBrush}"
                                   FontSize="11" FontWeight="SemiBold"/>
                    </Border>

                    <Border x:Name="AdminBadge" Style="{StaticResource Badge}"
                            Background="{StaticResource SuccessMuted}"
                            BorderBrush="{StaticResource SuccessBrush}">
                        <TextBlock x:Name="AdminBadgeText"
                                   Text="● Administrator"
                                   Foreground="{StaticResource SuccessBrush}"
                                   FontSize="11" FontWeight="SemiBold"/>
                    </Border>

                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Row 1 – Admin warning ══════════════════════════════════════════ -->
        <Border Grid.Row="1" x:Name="AdminWarningPanel"
                Margin="14,8,14,0" Padding="14,11"
                Background="{StaticResource WarningMuted}"
                BorderBrush="{StaticResource WarningBrush}"
                BorderThickness="1" CornerRadius="9"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="⚠  Administrator permission required"
                               Foreground="{StaticResource WarningBrush}"
                               FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock Text="DNS changes require elevated privileges. Click the button to restart with admin rights."
                               Foreground="#C88820" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" x:Name="RestartAdminBtn"
                        Content="Restart as Administrator"
                        Style="{StaticResource PrimaryBtn}"
                        Background="{StaticResource WarningBrush}"
                        VerticalAlignment="Center"
                        Click="RestartAdmin_Click"/>
            </Grid>
        </Border>

        <!-- ══ Row 2 – Main content ════════════════════════════════════════════ -->
        <Grid Grid.Row="2" Margin="14,10,14,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>   <!-- Left: adapters  -->
                <ColumnDefinition Width="1"/>     <!-- Divider         -->
                <ColumnDefinition Width="*"/>     <!-- Right: controls -->
            </Grid.ColumnDefinitions>

            <!-- ── Left: Adapter list ───────────────────────────────────────── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="ACTIVE ADAPTERS" Style="{StaticResource SectionLabel}"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="RefreshBtn" Content="↻"
                            Style="{StaticResource IconBtn}"
                            ToolTip="Refresh adapter list"
                            Click="Refresh_Click"/>
                </Grid>

                <ListBox Grid.Row="1" x:Name="AdapterListBox"
                         Style="{StaticResource DarkListBox}"
                         SelectionChanged="AdapterListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Width="3" RadiusX="2" RadiusY="2"
                                           Fill="{StaticResource AccentBrush}"
                                           VerticalAlignment="Stretch" Margin="0,2,0,2"/>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{StaticResource TextBrush}"
                                               FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{Binding Description}"
                                               Foreground="{StaticResource SubTextBrush}"
                                               FontSize="10" TextTrimming="CharacterEllipsis"
                                               Margin="0,1,0,4"/>
                                    <!-- IPv4 row -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="v4" Foreground="{StaticResource SuccessBrush}"
                                                   FontSize="9.5" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding IPv4DnsDisplay}"
                                                   Foreground="{StaticResource SuccessBrush}"
                                                   FontSize="10" FontFamily="Consolas"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                    <!-- IPv6 row -->
                                    <Grid Margin="0,1,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="v6" Foreground="{StaticResource AccentBrush}"
                                                   FontSize="9.5" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding IPv6DnsDisplay}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontSize="10" FontFamily="Consolas"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Grid.Row="2" x:Name="NoAdaptersText"
                           Text="No active adapters found"
                           Foreground="{StaticResource SubTextBrush}"
                           FontSize="11" HorizontalAlignment="Center"
                           Margin="0,8,0,0" Visibility="Collapsed"/>
            </Grid>

            <!-- Divider -->
            <Rectangle Grid.Column="1" Fill="{StaticResource DividerBrush}"
                       Width="1" VerticalAlignment="Stretch" Margin="6,0"/>

            <!-- ── Right: Controls ───────────────────────────────────────────── -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="16,0,4,16">

                    <!-- ─── DNS Presets ────────────────────────────────────── -->
                    <TextBlock Text="DNS PRESETS" Style="{StaticResource SectionLabel}"/>

                    <UniformGrid Columns="3" Margin="0,0,0,14">

                        <!-- Google -->
                        <Button x:Name="GoogleBtn" Style="{StaticResource PresetCard}"
                                Margin="0,0,6,0" Click="Google_Click">
                            <Grid>
                                <!-- Accent top bar -->
                                <Border x:Name="GoogleTopBar"
                                        Height="3" VerticalAlignment="Top"
                                        Background="{StaticResource GoogleBrush}"
                                        CornerRadius="10,10,0,0"/>
                                <StackPanel Margin="14,14,14,13">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Ellipse Width="9" Height="9" Fill="{StaticResource GoogleBrush}"
                                                 VerticalAlignment="Center" Margin="0,0,7,0"/>
                                        <TextBlock Text="Google"
                                                   Foreground="{StaticResource GoogleBrush}"
                                                   FontWeight="Bold" FontSize="13.5"/>
                                    </StackPanel>
                                    <TextBlock Text="8.8.8.8 / 8.8.4.4"
                                               Foreground="{StaticResource SubTextBrush}"
                                               FontFamily="Consolas" FontSize="10.5"/>
                                    <TextBlock Text="Fast &amp; reliable"
                                               Foreground="{StaticResource DimTextBrush}"
                                               FontSize="9.5" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <!-- Cloudflare -->
                        <Button x:Name="CloudflareBtn" Style="{StaticResource PresetCard}"
                                Margin="3,0,3,0" Click="Cloudflare_Click">
                            <Grid>
                                <Border Height="3" VerticalAlignment="Top"
                                        Background="{StaticResource CloudflareBrush}"
                                        CornerRadius="10,10,0,0"/>
                                <StackPanel Margin="14,14,14,13">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Ellipse Width="9" Height="9" Fill="{StaticResource CloudflareBrush}"
                                                 VerticalAlignment="Center" Margin="0,0,7,0"/>
                                        <TextBlock Text="Cloudflare"
                                                   Foreground="{StaticResource CloudflareBrush}"
                                                   FontWeight="Bold" FontSize="13.5"/>
                                    </StackPanel>
                                    <TextBlock Text="1.1.1.1 / 1.0.0.1"
                                               Foreground="{StaticResource SubTextBrush}"
                                               FontFamily="Consolas" FontSize="10.5"/>
                                    <TextBlock Text="Privacy-first, fastest"
                                               Foreground="{StaticResource DimTextBrush}"
                                               FontSize="9.5" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <!-- Quad9 -->
                        <Button x:Name="Quad9Btn" Style="{StaticResource PresetCard}"
                                Margin="6,0,0,0" Click="Quad9_Click">
                            <Grid>
                                <Border Height="3" VerticalAlignment="Top"
                                        Background="{StaticResource Quad9Brush}"
                                        CornerRadius="10,10,0,0"/>
                                <StackPanel Margin="14,14,14,13">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Ellipse Width="9" Height="9" Fill="{StaticResource Quad9Brush}"
                                                 VerticalAlignment="Center" Margin="0,0,7,0"/>
                                        <TextBlock Text="Quad9"
                                                   Foreground="{StaticResource Quad9Brush}"
                                                   FontWeight="Bold" FontSize="13.5"/>
                                    </StackPanel>
                                    <TextBlock Text="9.9.9.9 / 149.112…"
                                               Foreground="{StaticResource SubTextBrush}"
                                               FontFamily="Consolas" FontSize="10.5"/>
                                    <TextBlock Text="Security / malware block"
                                               Foreground="{StaticResource DimTextBrush}"
                                               FontSize="9.5" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Button>
                    </UniformGrid>

                    <!-- ─── Custom DNS ─────────────────────────────────────── -->
                    <TextBlock Text="CUSTOM DNS" Style="{StaticResource SectionLabel}"/>

                    <Border Style="{StaticResource InfoCard}">
                        <StackPanel>
                            <!-- IPv4 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="6" Height="6" CornerRadius="3"
                                        Background="{StaticResource SuccessBrush}"
                                        VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="IPv4" Foreground="{StaticResource SuccessBrush}"
                                           FontSize="10.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Primary" Foreground="{StaticResource SubTextBrush}"
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtIPv4Primary" Style="{StaticResource DarkTextBox}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Secondary" Foreground="{StaticResource SubTextBrush}"
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtIPv4Secondary" Style="{StaticResource DarkTextBox}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Divider -->
                            <Rectangle Height="1" Fill="{StaticResource DividerBrush}" Margin="0,0,0,12"/>

                            <!-- IPv6 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="6" Height="6" CornerRadius="3"
                                        Background="{StaticResource AccentBrush}"
                                        VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="IPv6" Foreground="{StaticResource AccentBrush}"
                                           FontSize="10.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Primary" Foreground="{StaticResource SubTextBrush}"
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtIPv6Primary" Style="{StaticResource DarkTextBox}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Secondary" Foreground="{StaticResource SubTextBrush}"
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtIPv6Secondary" Style="{StaticResource DarkTextBox}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ─── Options ────────────────────────────────────────── -->
                    <TextBlock Text="OPTIONS" Style="{StaticResource SectionLabel}"/>

                    <Border Style="{StaticResource InfoCard}">
                        <StackPanel>
                            <CheckBox x:Name="ChkSetIPv6" Style="{StaticResource DarkCheck}" IsChecked="True">
                                <StackPanel>
                                    <TextBlock Text="Set IPv6 DNS too" Style="{StaticResource CardTitle}" FontSize="12"/>
                                    <TextBlock Text="Recommended on Windows 11 — IPv6 DNS can silently override IPv4 DNS."
                                               Style="{StaticResource CardSub}" FontSize="10"/>
                                </StackPanel>
                            </CheckBox>

                            <Rectangle Height="1" Fill="{StaticResource DividerBrush}" Margin="0,10,0,10"/>

                            <CheckBox x:Name="ChkDisableIPv6" Style="{StaticResource DarkCheck}" IsChecked="False"
                                      Checked="ChkDisableIPv6_Checked" Unchecked="ChkDisableIPv6_Unchecked">
                                <StackPanel>
                                    <TextBlock Text="Disable IPv6 on selected adapter"
                                               Foreground="{StaticResource ErrorBrush}" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock Text="Nuclear option — use only if changing IPv6 DNS doesn't fix the problem."
                                               Style="{StaticResource CardSub}" FontSize="10"/>
                                </StackPanel>
                            </CheckBox>

                            <Rectangle Height="1" Fill="{StaticResource DividerBrush}" Margin="0,10,0,10"/>

                            <CheckBox x:Name="ChkApplyAll" Style="{StaticResource DarkCheck}" IsChecked="False">
                                <TextBlock Text="Apply to all active adapters" Style="{StaticResource CardTitle}" FontSize="12"/>
                            </CheckBox>
                        </StackPanel>
                    </Border>

                    <!-- ─── Discord Connectivity ───────────────────────────── -->
                    <TextBlock Text="DISCORD CONNECTIVITY" Style="{StaticResource SectionLabel}"/>

                    <Border Style="{StaticResource InfoCard}">
                        <StackPanel>

                            <!-- Test row -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Test Discord Connection"
                                               Style="{StaticResource CardTitle}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Checks DNS, ping, TCP 443, WebSocket gateway, and CDN update endpoint."
                                               Style="{StaticResource CardSub}"/>
                                </StackPanel>
                                <Button Grid.Column="1" x:Name="TestDiscordBtn"
                                        Content="⚡  Test"
                                        Style="{StaticResource PrimaryBtn}"
                                        Background="{StaticResource AccentBrush}"
                                        VerticalAlignment="Center"
                                        Margin="14,0,0,0"
                                        Click="TestDiscord_Click"/>
                            </Grid>

                            <Rectangle Height="1" Fill="{StaticResource DividerBrush}" Margin="0,0,0,12"/>

                            <!-- Hosts patch row -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="Patch Hosts File"
                                                   Style="{StaticResource CardTitle}"/>
                                        <Border x:Name="HostsStatusBadge"
                                                CornerRadius="4" Padding="6,2"
                                                Background="{StaticResource Surface2Brush}"
                                                BorderBrush="{StaticResource CardBorderBrush}"
                                                BorderThickness="1"
                                                VerticalAlignment="Center"
                                                Margin="8,0,0,0">
                                            <TextBlock x:Name="HostsStatusText"
                                                       Text="not patched"
                                                       Foreground="{StaticResource SubTextBrush}"
                                                       FontSize="9.5" FontFamily="Consolas"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="Resolves all Discord domains via Google DNS and writes IPs to hosts file. Fixes 'stuck on updates' on blocked networks (e.g. Turkcell Superonline)."
                                               Style="{StaticResource CardSub}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                            VerticalAlignment="Center" Margin="14,0,0,0">
                                    <Button x:Name="PatchHostsBtn"
                                            Content="🛠  Patch"
                                            Style="{StaticResource PrimaryBtn}"
                                            Background="#2A5A3A"
                                            Foreground="#5EE89A"
                                            Margin="0,0,6,0"
                                            Click="PatchHosts_Click"/>
                                    <Button x:Name="RemoveHostsBtn"
                                            Content="✕"
                                            Style="{StaticResource SecondaryBtn}"
                                            Padding="10,9"
                                            ToolTip="Remove hosts file entries"
                                            Click="RemoveHosts_Click"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ─── Actions ────────────────────────────────────────── -->
                    <TextBlock Text="ACTIONS" Style="{StaticResource SectionLabel}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" x:Name="ApplyBtn"
                                Style="{StaticResource PrimaryBtn}"
                                Padding="0,12"
                                HorizontalAlignment="Stretch"
                                Click="Apply_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="▶" FontSize="11" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock Text="Apply DNS" FontSize="13.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2" x:Name="RestoreBtn"
                                Style="{StaticResource SecondaryBtn}"
                                Padding="0,12"
                                HorizontalAlignment="Stretch"
                                Click="Restore_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="↺" FontSize="13" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock Text="Restore Auto" FontSize="12.5" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="4" x:Name="TestBtn"
                                Style="{StaticResource SecondaryBtn}"
                                Padding="0,12"
                                HorizontalAlignment="Stretch"
                                Click="Test_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚡" FontSize="11" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock Text="Test DNS" FontSize="12.5" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ══ Success Overlay ═══════════════════════════════════════════════ -->
        <!-- Covers rows 0-3, sits above everything, hidden by default -->
        <Grid Grid.Row="0" Grid.RowSpan="4"
              x:Name="SuccessOverlay"
              Visibility="Collapsed"
              Panel.ZIndex="99">
            <!-- Dim backdrop -->
            <Rectangle Fill="#CC000010"/>

            <!-- Card -->
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="#131328"
                    BorderBrush="#5865F2"
                    BorderThickness="2"
                    CornerRadius="18"
                    Padding="48,40"
                    MinWidth="420">
                <Border.Effect>
                    <DropShadowEffect Color="#5865F2" BlurRadius="40" ShadowDepth="0" Opacity="0.35"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">

                    <!-- Big checkmark -->
                    <Border Width="80" Height="80" CornerRadius="40"
                            Background="#1A3A28"
                            BorderBrush="#3EC97E" BorderThickness="2.5"
                            HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Text="✓" FontSize="38" FontWeight="Bold"
                                   Foreground="#3EC97E"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Title -->
                    <TextBlock Text="Discord is Reachable!"
                               FontSize="24" FontWeight="Bold"
                               Foreground="#EAEAF2"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>

                    <!-- Sub message -->
                    <TextBlock x:Name="SuccessSubText"
                               Text="DNS resolved, internet reachable, TCP 443 open."
                               FontSize="13"
                               Foreground="#7878A8"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,0,0,28"/>

                    <!-- Dismiss button -->
                    <Button Content="Got it  ✓"
                            Style="{StaticResource PrimaryBtn}"
                            Background="#3EC97E"
                            Padding="36,12"
                            FontSize="14"
                            HorizontalAlignment="Center"
                            Click="DismissSuccess_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══ Row 3 – Log panel ══════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="{StaticResource LogBgBrush}"
                BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,1,0,0"
                Margin="0,8,0,0">
            <Grid Margin="14,8,14,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="OUTPUT LOG" Style="{StaticResource SectionLabel}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Border CornerRadius="4" Padding="6,2" Background="#10102A"
                                BorderBrush="{StaticResource DividerBrush}" BorderThickness="1"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="LogCountLabel" Text="0 lines"
                                       Foreground="{StaticResource DimTextBrush}"
                                       FontSize="9.5" FontFamily="Consolas"/>
                        </Border>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Clear log"
                            Style="{StaticResource IconBtn}"
                            Padding="10,4" FontSize="11"
                            Foreground="{StaticResource SubTextBrush}"
                            Click="ClearLog_Click"/>
                </Grid>

                <TextBox Grid.Row="1" x:Name="LogBox"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         Background="Transparent"
                         Foreground="{StaticResource LogTextBrush}"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="11"
                         Padding="2,2"
                         VerticalContentAlignment="Top"/>
            </Grid>
        </Border>

    </Grid>
</Window>
